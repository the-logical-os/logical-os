  <environment>
    <id>illogical-impulse</id>
    <name>Illogical Impulse</name>
    <description>Hyprland Illogical Impulse shell (by end-4).</description>
    <uservisible>true</uservisible>

    <grouplist>
        <groupid>core</groupid>
        <groupid>sound</groupid>
        <groupid>additional</groupid>
        <groupid>ii-basic</groupid>
        <groupid>fonts-and-themes</groupid>
        <groupid>hyprland</groupid>
        <groupid>kde</groupid>
        <groupid>python</groupid>
        <groupid>screencapture</groupid>
        <groupid>toolkit</groupid>
        <groupid>widgets</groupid>
        <groupid>quickshell</groupid>
        <groupid>utilities</groupid>
    </grouplist>

    <optionlist>
        <groupid>plasma-toolkit</groupid>
        <groupid>gnome-toolkit</groupid>
    </optionlist>
  </environment>
